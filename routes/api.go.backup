package routes

import (
	"awesomeProject/config"
	"awesomeProject/controllers"
	"awesomeProject/middleware"
	"awesomeProject/models"
	"fmt"
	"net/http"

	"github.com/gin-gonic/gin"
)

func SetupRoutes(r *gin.Engine) {
	// Middleware setup
	// r.Use(middleware.Logger())
	// r.Use(middleware.CORSMiddleware())

	// Simple test route
	r.GET("/test", func(c *gin.Context) {
		fmt.Printf("DEBUG: Root test route called!\n")
		c.JSON(http.StatusOK, gin.H{"message": "Root test route works!"})
	})

	api := r.Group("/api/v1")

	// Public routes
	auth := api.Group("/auth")
	{
		auth.POST("/login", controllers.Login)
		auth.POST("/signup", controllers.Register)
		auth.POST("/logout", controllers.Logout)
		auth.PUT("/status", controllers.UpdateUserStatus)
	}

	// Accounts routes (temporarily public for testing) - moved here
	accounts := api.Group("/accounts")
	accounts.Use(func(c *gin.Context) {
		fmt.Printf("DEBUG: Accounts middleware called for path: %s\n", c.Request.URL.Path)
		c.Next()
	})
	{
		accounts.GET("/test", controllers.TestAccounts)
		accounts.GET("/ledger", controllers.GetLedgerEntries)
		accounts.POST("/ledger", controllers.CreateLedgerEntry)
		accounts.PUT("/ledger/:id", controllers.UpdateLedgerEntry)
		accounts.DELETE("/ledger/:id", controllers.DeleteLedgerEntry)
		controllers.RegisterGenericCRUD[models.Expense](accounts, "/expenses")
	}

	// Protected routes that don't require company context
	authProtected := api.Group("/auth")
	authProtected.Use(middleware.AuthMiddleware())
	{
		authProtected.GET("/me", controllers.GetMe)
	}

	// Protected routes for user's own companies
	userCompanies := api.Group("/companies")
	userCompanies.Use(middleware.AuthMiddleware())
	{
		userCompanies.GET("", controllers.GetUserCompanies)
		userCompanies.POST("", controllers.CreateUserCompany)
	}

	// Protected routes with multi-tenancy support
	protected := api.Group("/")
	protected.Use(middleware.AuthMiddleware())
	protected.Use(middleware.CompanyMiddleware(config.DB))
	protected.Use(middleware.AuditMiddleware())
	{
		protected.GET("/dashboard", controllers.GetDashboardData)

		// Users and sub-user management
		SetupUserRoutes(r, config.DB)

		// Subscribers (with RBAC)
		subscribers := protected.Group("/subscribers")
		subscribers.Use(middleware.RBACMiddleware(config.DB, "subscribers", "read"))
		{
			subscriberCRUD := controllers.GenericCRUD[models.Subscriber]{IsScoped: true}
			subscribers.GET("", subscriberCRUD.FindAll)
			subscribers.POST("", middleware.RBACMiddleware(config.DB, "subscribers", "add"), controllers.CreateSubscriber)
			subscribers.PUT("/:id", middleware.RBACMiddleware(config.DB, "subscribers", "edit"), controllers.UpdateSubscriber)
			subscribers.DELETE("/:id", middleware.RBACMiddleware(config.DB, "subscribers", "delete"), controllers.DeleteSubscriber)
		}

		// Billing / Ledger
		billing := protected.Group("/billing")
		billing.Use(middleware.RBACMiddleware(config.DB, "billing", "read"))
		{
			// Payment processing routes (different from CRUD)
			billing.POST("/payments/process", middleware.RBACMiddleware(config.DB, "billing", "add"), controllers.ProcessPayment)
		}

		// Network (with RBAC)
		network := protected.Group("/network")
		network.Use(middleware.RBACMiddleware(config.DB, "network", "read"))
		{
			controllers.RegisterGenericCRUD[models.Area](network, "/areas")
			controllers.RegisterGenericCRUD[models.OLT](network, "/olts")
			controllers.RegisterGenericCRUD[models.OLT](network, "/olt") // Alias
			controllers.RegisterGenericCRUD[models.Splitter](network, "/splitters")
			controllers.RegisterGenericCRUD[models.POP](network, "/pops")
			controllers.RegisterGenericCRUD[models.POP](network, "/pop") // Alias
		}

		// Dealers (with RBAC)
		dealers := protected.Group("/dealers")
		dealers.Use(middleware.RBACMiddleware(config.DB, "dealers", "read"))
		{
			dealers.GET("/dashboard", controllers.GetDealerDashboard)
			dealers.GET("/franchise-dashboard", controllers.GetFranchiseDashboard)
			dealerCRUD := controllers.GenericCRUD[models.Dealer]{IsScoped: true}
			dealers.GET("", dealerCRUD.FindAll)
			dealers.PUT("/:id", middleware.RBACMiddleware(config.DB, "dealers", "edit"), dealerCRUD.Update)
			dealers.DELETE("/:id", middleware.RBACMiddleware(config.DB, "dealers", "delete"), dealerCRUD.Delete)
			controllers.RegisterGenericCRUD[models.DealerFranchise](dealers, "/franchises")
			dealers.POST("", middleware.RBACMiddleware(config.DB, "dealers", "add"), controllers.CreateDealer)
			dealers.POST("/sub-dealer", middleware.RBACMiddleware(config.DB, "dealers", "add"), controllers.CreateSubDealer)
		}

		// Admin routes (owner/admin only)
		admin := protected.Group("/admin")
		admin.Use(middleware.RequireOwnerOrAdmin(config.DB))
		{
			// Companies
			companies := admin.Group("/companies")
			companies.Use(middleware.RBACMiddleware(config.DB, "companies", "read"))
			{
				companyCRUD := controllers.GenericCRUD[models.Company]{IsScoped: true}
				companies.GET("", companyCRUD.FindAll)
				companies.PUT("/:id", middleware.RBACMiddleware(config.DB, "companies", "edit"), companyCRUD.Update)
				companies.DELETE("/:id", middleware.RBACMiddleware(config.DB, "companies", "delete"), companyCRUD.Delete)
				companies.POST("", middleware.RBACMiddleware(config.DB, "companies", "add"), controllers.CreateCompany)
			}

			// Roles and permissions
			roles := admin.Group("/roles")
			roles.Use(middleware.RBACMiddleware(config.DB, "roles", "read"))
			{
				controllers.RegisterGenericCRUD[models.Role](roles, "")
				controllers.RegisterGenericCRUD[models.Permission](roles, "/permissions")
				controllers.RegisterGenericCRUD[models.RolePermission](roles, "/role-permissions")
			}

			// System logs
			logs := admin.Group("/logs")
			logs.Use(middleware.RBACMiddleware(config.DB, "logs", "read"))
			{
				logs.GET("", controllers.GetSystemLogs)
				logs.GET("/user/:userId", controllers.GetUserLogs)
				logs.GET("/module/:module", controllers.GetModuleLogs)
			}
		}

		// Analytics / Reports routes (with RBAC)
		reports := protected.Group("/reports")
		reports.Use(middleware.RBACMiddleware(config.DB, "reports", "read"))
		{
			reports.GET("/sales-vs-recovery", controllers.GetSalesVsRecovery)
			reports.GET("/billing", controllers.GetBillingReport)
			reports.GET("/outstanding", controllers.GetOutstandingReport)
		}

		// Recovery routes (with RBAC)
		recovery := protected.Group("/recovery")
		recovery.Use(middleware.RBACMiddleware(config.DB, "recovery", "read"))
		{
			controllers.RegisterGenericCRUD[models.RecoveryTransaction](recovery, "/transactions")
		}

		// HR routes (with RBAC)
		hr := protected.Group("/hr")
		hr.Use(middleware.RBACMiddleware(config.DB, "hr", "read"))
		{
			controllers.RegisterGenericCRUD[models.Staff](hr, "/staff")
			controllers.RegisterGenericCRUD[models.Attendance](hr, "/attendance")
			controllers.RegisterGenericCRUD[models.AdvanceLoan](hr, "/advances")
		}

		// CRM routes (with RBAC)
		crm := protected.Group("/crm")
		crm.Use(middleware.RBACMiddleware(config.DB, "crm", "read"))
		{
			controllers.RegisterGenericCRUD[models.Customer](crm, "/customers")
			controllers.RegisterGenericCRUD[models.Guarantor](crm, "/guarantors")
		}

		// Support routes (with RBAC)
		support := protected.Group("/support")
		support.Use(middleware.RBACMiddleware(config.DB, "support", "read"))
		{
			controllers.RegisterGenericCRUD[models.Complaint](support, "/complaints")
			controllers.RegisterGenericCRUD[models.AlertTemplate](support, "/alerts")
		}

		// Additional subscriber routes
		subscribersExtra := protected.Group("/subscribers")
		subscribersExtra.Use(middleware.RBACMiddleware(config.DB, "subscribers", "read"))
		{
			controllers.RegisterGenericCRUD[models.Inquiry](subscribersExtra, "/inquiries")
			controllers.RegisterGenericCRUD[models.CorporateCustomer](subscribersExtra, "/corporate")
		}

		// Inventory & Products (with RBAC)
		inventory := protected.Group("/inventory")
		inventory.Use(middleware.RBACMiddleware(config.DB, "inventory", "read"))
		{
			controllers.RegisterGenericCRUD[models.InventoryItem](inventory, "/items")
			controllers.RegisterGenericCRUD[models.Product](inventory, "/products")
			controllers.RegisterGenericCRUD[models.PricingPlan](inventory, "/plans")
			controllers.RegisterGenericCRUD[models.Sale](inventory, "/sales")
		}

		// Sales routes (with RBAC)
		sales := protected.Group("/sales")
		sales.Use(middleware.RBACMiddleware(config.DB, "sales", "read"))
		{
			controllers.RegisterGenericCRUD[models.InstallmentPlan](sales, "/installment-plans")
		}

		// Additional billing routes
		billingExtra := protected.Group("/billing")
		billingExtra.Use(middleware.RBACMiddleware(config.DB, "billing", "read"))
		{
			controllers.RegisterGenericCRUD[models.Package](billingExtra, "/packages")
			controllers.RegisterGenericCRUD[models.Invoice](billingExtra, "/invoices")
			billingExtra.GET("/payments", controllers.GetPayments)
			billingExtra.POST("/payments", middleware.RBACMiddleware(config.DB, "billing", "add"), controllers.CreatePayment)
			billingExtra.PUT("/payments/:id", middleware.RBACMiddleware(config.DB, "billing", "edit"), controllers.UpdatePayment)
			billingExtra.DELETE("/payments/:id", middleware.RBACMiddleware(config.DB, "billing", "delete"), controllers.GenericCRUD[models.Payment]{IsScoped: true}.Delete)
			billingExtra.GET("/custom-bills", controllers.GetCustomBills)
			billingExtra.POST("/custom-bills", middleware.RBACMiddleware(config.DB, "billing", "add"), controllers.CreateCustomBill)
			billingExtra.PUT("/custom-bills/:id", middleware.RBACMiddleware(config.DB, "billing", "edit"), controllers.UpdateCustomBill)
			billingExtra.DELETE("/custom-bills/:id", middleware.RBACMiddleware(config.DB, "billing", "delete"), controllers.GenericCRUD[models.CustomBill]{IsScoped: true}.Delete)
			controllers.RegisterGenericCRUD[models.LedgerEntry](billingExtra, "/ledger")
			controllers.RegisterGenericCRUD[models.Expense](billingExtra, "/expenses")
		}
	}
}
